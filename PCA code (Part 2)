def apply_thesis_style(ax):
    ax.spines['top'].set_visible(False)
    ax.spines['right'].set_visible(False)
    ax.spines['left'].set_linewidth(0.8)
    ax.spines['bottom'].set_linewidth(0.8)
    ax.tick_params(axis='both', direction='in', length=4, width=0.8)
    ax.grid(False)


# ─────────────────────────────────────────────
#  Utility helpers
# ─────────────────────────────────────────────

def get_integration_time(filename):
    match = re.search(r'(\d{2,3})ms', os.path.basename(filename))
    return float(match.group(1)) if match else None


def extract_experiment_params(filename):
    """Extracts Power (W), Pressure (mTorr), and Argon % from filename."""
    base = os.path.basename(filename)
    power_m    = re.search(r'(\d+\.?\d*)\s*W',     base, re.IGNORECASE)
    pressure_m = re.search(r'(\d+\.?\d*)\s*mTorr', base, re.IGNORECASE)
    argon_m    = re.search(r'argon(\d+\.?\d*)%',   base, re.IGNORECASE)
    power    = float(power_m.group(1))    if power_m    else None
    pressure = float(pressure_m.group(1)) if pressure_m else None
    argon    = float(argon_m.group(1))    if argon_m    else None
    return power, pressure, argon


def clean_name(filepath):
    return os.path.basename(filepath)


def validate_parameters(min_height, min_distance, wavelength_tolerance):
    if min_height < 0:
        raise ValueError("Minimum height must be non-negative")
    if min_distance < 1:
        raise ValueError("Minimum distance must be at least 1")
    if wavelength_tolerance < 0:
        raise ValueError("Wavelength tolerance must be non-negative")
    return min_height, min_distance, wavelength_tolerance


# ─────────────────────────────────────────────
#  File loading
# ─────────────────────────────────────────────

def load_reference_peaks_csv(csv_file):
    df = pd.read_csv(csv_file, comment='#', encoding='utf-8')
    required = {'wavelength_nm', 'intensity'}
    if not required.issubset(df.columns):
        raise ValueError(f"Reference CSV must contain columns: {required}. Found: {set(df.columns)}")

    if 'intensity_per_ms' in df.columns and df['intensity_per_ms'].notna().any():
        intensities = df['intensity_per_ms'].values
        print("Using 'intensity_per_ms' column from reference CSV.")
    else:
        intensities = df['intensity'].values
        print("Using raw 'intensity' column from reference CSV.")

    peaks = list(zip(df['wavelength_nm'].values, intensities))
    print(f"Loaded {len(peaks)} reference peaks from {os.path.basename(csv_file)}")
    return peaks


def load_oes_data_simple(filename):
    try:
        with open(filename, 'r') as f:
            first_line = f.readline().strip()

        if 'wavelength_nm' in first_line and 'cal_intensity' in first_line:
            df = pd.read_csv(filename)
            return df['wavelength_nm'].values, df['cal_intensity'].values

        with open(filename, 'r') as f:
            lines = f.readlines()

        data_lines = []
        for line in lines:
            parts = line.strip().split()
            if len(parts) >= 2:
                try:
                    float(parts[0]); float(parts[1])
                    data_lines.append(line.strip())
                except ValueError:
                    continue

        if not data_lines:
            raise ValueError("No numeric data found")

        data = np.array([[float(p) for p in l.split()[:2]] for l in data_lines])
        return data[:, 0], data[:, 1]

    except Exception as e:
        print(f"Error loading {filename}: {e}")
        return None, None


# ─────────────────────────────────────────────
#  Intensity lookup
# ─────────────────────────────────────────────

def get_intensity_at_wavelength(wavelength_array, intensity_array,
                                 target_wavelength, tolerance=0.1):
    diffs = np.abs(wavelength_array - target_wavelength)
    idx   = np.argmin(diffs)
    if diffs[idx] <= tolerance:
        return intensity_array[idx], diffs[idx]
    return 0.0, diffs[idx]


def get_peak_intensity(wavelength_array, intensity_array, target_wl, tolerance=1.0):
    mask = ((wavelength_array >= target_wl - tolerance) &
            (wavelength_array <= target_wl + tolerance))
    if not np.any(mask):
        return 0.0
    return np.max(intensity_array[mask])


# ─────────────────────────────────────────────
#  Vibrational temperature
# ─────────────────────────────────────────────

def calculate_vibrational_temperature(wavelength, intensity, sample_name=""):
    I_00 = get_peak_intensity(wavelength, intensity, 337.13, tolerance=1.0)
    I_10 = get_peak_intensity(wavelength, intensity, 315.93, tolerance=1.0)

    if I_00 <= 0 or I_10 <= 0:
        return None, None

    try:
        ratio = (I_00 * 0.388 * 337.13**4) / (I_10 * 0.449 * 315.93**4)
        Tvib  = 2012 / (0.695 * math.log(ratio))
        return Tvib, None
    except (ValueError, ZeroDivisionError):
        return None, None


# ─────────────────────────────────────────────
#  Core analysis
# ─────────────────────────────────────────────

def analyse_samples_against_reference_peaks(reference_peaks, sample_files,
                                             wavelength_tolerance=0.1):
    results = {
        'reference_peaks': reference_peaks,
        'sample_results':  {},
    }

    for sample_file in sample_files:
        print(f"\nAnalysing: {clean_name(sample_file)}")
        wavelength, intensity = load_oes_data_simple(sample_file)

        if wavelength is None:
            print(f"  Could not load file — skipping.")
            continue

        int_time = get_integration_time(sample_file)
        if int_time:
            print(f"  Integration time: {int_time} ms — normalising.")
            intensity = intensity / int_time
        else:
            print("  No integration time in filename — using raw counts.")

        t_vib, _ = calculate_vibrational_temperature(wavelength, intensity,
                                                     sample_name=clean_name(sample_file))

        peak_data = []
        for ref_wl, ref_int in reference_peaks:
            sample_int, wl_diff = get_intensity_at_wavelength(
                wavelength, intensity, ref_wl, wavelength_tolerance
            )
            peak_data.append({
                'wavelength':            ref_wl,
                'reference_intensity':   ref_int,
                'sample_intensity':      sample_int,
                'intensity_ratio':       sample_int / ref_int if ref_int > 0 else 0.0,
                'wavelength_difference': wl_diff,
                'within_tolerance':      wl_diff <= wavelength_tolerance,
            })

        results['sample_results'][sample_file] = {
            'peak_data':               peak_data,
            'wavelength':              wavelength,
            'intensity':               intensity,
            'integration_time':        int_time,
            'Vibrational Temperature': t_vib,
        }

        in_tol = sum(1 for p in peak_data if p['within_tolerance'])
        print(f"  Peaks matched within tolerance: {in_tol}/{len(peak_data)}")
        if t_vib:
            print(f"  Vibrational Temperature: {t_vib:.1f} K")

    return results


# ─────────────────────────────────────────────
#  Saving results
# ─────────────────────────────────────────────

def save_results(results, reference_csv, output_file):
    with open(output_file, 'w') as f:
        f.write("MULTI-SAMPLE OES ANALYSIS — Part 2\n")
        f.write("=" * 60 + "\n")
        f.write(f"Reference peaks CSV : {reference_csv}\n")
        f.write(f"Number of ref peaks : {len(results['reference_peaks'])}\n")
        f.write(f"Analysis date       : {np.datetime64('now')}\n\n")

        f.write("REFERENCE PEAKS\n")
        f.write("-" * 60 + "\n")
        for i, (wl, inten) in enumerate(results['reference_peaks'], 1):
            f.write(f"  {i:3d}. {wl:.4f} nm   intensity = {inten:.4f}\n")
        f.write("\n")

        for sample_file, data in results['sample_results'].items():
            f.write(f"SAMPLE: {clean_name(sample_file)}\n")
            t = data.get('integration_time')
            f.write(f"  Integration time : {t} ms\n" if t else "  Integration time : not found\n")
            tv = data.get('Vibrational Temperature')
            f.write(f"  Tvib             : {tv:.2f} K\n\n" if tv else "  Tvib             : N/A\n\n")

            for i, p in enumerate(data['peak_data'], 1):
                sym = "+" if p['within_tolerance'] else "-"
                f.write(f"  Peak {i:3d}: {p['wavelength']:.4f} nm [{sym}]\n")
                f.write(f"    Ref intensity    : {p['reference_intensity']:.4f}\n")
                f.write(f"    Sample intensity : {p['sample_intensity']:.4f}\n")
                f.write(f"    Ratio            : {p['intensity_ratio']:.4f}\n")
                f.write(f"    Wavelength diff  : {p['wavelength_difference']:.4f} nm\n\n")

        f.write("SUMMARY\n")
        f.write("-" * 60 + "\n")
        for sample_file, data in results['sample_results'].items():
            total  = len(data['peak_data'])
            in_tol = sum(1 for p in data['peak_data'] if p['within_tolerance'])
            ratios = [p['intensity_ratio'] for p in data['peak_data']
                      if p['within_tolerance'] and p['reference_intensity'] > 0]
            avg_r  = np.mean(ratios) if ratios else 0
            f.write(f"{clean_name(sample_file)}\n")
            f.write(f"  Matched peaks : {in_tol}/{total} ({in_tol/total:.0%})\n")
            f.write(f"  Avg ratio     : {avg_r:.4f}\n\n")


