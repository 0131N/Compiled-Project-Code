def plot_sample_spectra(results):
    n = len(results['sample_results'])
    if n == 0:
        return

    ref_wls = [p[0] for p in results['reference_peaks']]
    fig, axes = plt.subplots(n, 1, figsize=(13, 4 * n), squeeze=False)

    for ax, (sample_file, data) in zip(axes[:, 0], results['sample_results'].items()):
        wl      = data['wavelength']
        iny     = data['intensity']
        y_label = 'Intensity / ms' if data.get('integration_time') else 'Intensity'

        ax.plot(wl, iny, color=COLOURS['teal'], linewidth=0.8, label='Sample spectrum')

        sample_ints = [p['sample_intensity'] for p in data['peak_data']]
        ax.plot(ref_wls, sample_ints, 'o', color=COLOURS['red'], markersize=6,
                label=f'Reference peak positions ({len(ref_wls)})')

        for wl_r, si in zip(ref_wls, sample_ints):
            ax.annotate(f'{si:.1f}', (wl_r, si),
                        xytext=(4, 4), textcoords='offset points',
                        fontsize=7, color=COLOURS['red'], alpha=0.8)

        tv = data.get('Vibrational Temperature')
        ax.set_xlabel('Wavelength (nm)')
        ax.set_ylabel(y_label)
        ax.legend(fontsize=8, frameon=False)
        apply_thesis_style(ax)
        if tv:
            ax.text(0.98, 0.95, f'$T_{{vib}}$ = {tv:.0f} K',
                    transform=ax.transAxes, ha='right', va='top',
                    fontsize=9, color=COLOURS['grey'])

    plt.tight_layout()
    plt.show()


def plot_vib_temp_trends(results):
    power_pts    = []
    pressure_pts = []

    for filename, data in results['sample_results'].items():
        tv = data.get('Vibrational Temperature')
        if tv is None:
            continue
        power, pressure, _ = extract_experiment_params(filename)
        if power    is not None: power_pts.append((power, tv))
        if pressure is not None: pressure_pts.append((pressure, tv))

    if not power_pts and not pressure_pts:
        print("No Power (W) or Pressure (mTorr) parameters found in filenames — skipping trend plot.")
        return

    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(12, 5))

    if power_pts:
        power_pts.sort()
        x, y = zip(*power_pts)
        ax1.plot(x, y, 'o-', color=COLOURS['blue'], linewidth=1.5, markersize=6)
        ax1.set_xlabel('Power (W)')
        ax1.set_ylabel('$T_{vib}$ (K)')
        apply_thesis_style(ax1)
    else:
        ax1.text(0.5, 0.5, 'No Power (W) data in filenames', ha='center', va='center',
                 transform=ax1.transAxes)
        apply_thesis_style(ax1)

    if pressure_pts:
        pressure_pts.sort()
        x, y = zip(*pressure_pts)
        ax2.plot(x, y, 'o-', color=COLOURS['red'], linewidth=1.5, markersize=6)
        ax2.set_xlabel('Pressure (mTorr)')
        ax2.set_ylabel('$T_{vib}$ (K)')
        apply_thesis_style(ax2)
    else:
        ax2.text(0.5, 0.5, 'No Pressure (mTorr) data in filenames', ha='center', va='center',
                 transform=ax2.transAxes)
        apply_thesis_style(ax2)

    plt.tight_layout()
    plt.show()


# ─────────────────────────────────────────────
#  PCA
# ─────────────────────────────────────────────

def perform_pca(results):
    print("\n--- PCA on reference-peak intensities ---")
    sample_names = []
    data_matrix  = []

    for sample_file, data in results['sample_results'].items():
        sample_names.append(clean_name(sample_file))
        data_matrix.append([p['sample_intensity'] for p in data['peak_data']])

    if len(data_matrix) < 2:
        print("Need at least 2 samples for PCA — skipping.")
        return None

    peak_labels = [f"{p[0]:.1f}nm" for p in results['reference_peaks']]
    df_pca = pd.DataFrame(data_matrix, columns=peak_labels, index=sample_names)

    scaler = StandardScaler()
    scaled = scaler.fit_transform(df_pca)

    pca = PCA()
    transformed = pca.fit_transform(scaled)
    eigenvalues  = pca.explained_variance_
    explained    = pca.explained_variance_ratio_ * 100

    for i, (eig, var) in enumerate(zip(eigenvalues, explained)):
        tag = "SIGNIFICANT" if eig > 1.0 else "noise"
        print(f"  PC{i+1}: λ={eig:.3f}  ({var:.1f}%)  [{tag}]")

    # Extract pressure and argon% per sample for colouring
    pressures  = []
    argon_pcts = []
    for sample_file in results['sample_results'].keys():
        _, pressure, argon = extract_experiment_params(sample_file)
        pressures.append(pressure)
        argon_pcts.append(argon)

    return {
        'transformed':   transformed,
        'eigenvalues':   eigenvalues,
        'explained_var': explained,
        'loadings':      pca.components_,
        'labels':        peak_labels,
        'samples':       sample_names,
        'pressures':     pressures,
        'argon_pcts':    argon_pcts,
    }


def plot_pca(pca_data):
    if pca_data is None:
        return

    pressures  = pca_data['pressures']
    argon_pcts = pca_data['argon_pcts']

    # ── Figure 1: Scree + Score plot ──────────────────────────────────
    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 5))

    # Scree plot
    ax1.bar(range(1, len(pca_data['eigenvalues']) + 1),
            pca_data['eigenvalues'], color=COLOURS['blue'], width=0.6)
    ax1.axhline(y=1, color=COLOURS['red'], linestyle='--', linewidth=1,
                label='Kaiser criterion (λ = 1)')
    ax1.set_xlabel('Principal Component')
    ax1.set_ylabel('Eigenvalue')
    ax1.legend(frameon=False, fontsize=9)
    apply_thesis_style(ax1)

    # Score plot — colour by pressure, marker shape by argon %
    valid_pressures = [p for p in pressures if p is not None]
    pressure_norm   = mcolors.Normalize(
        vmin=min(valid_pressures) * 0.8,
        vmax=max(valid_pressures) * 1.1
    ) if valid_pressures else mcolors.Normalize(0, 1)
    pressure_cmap = plt.get_cmap('Blues')

    unique_argons = sorted(set(a for a in argon_pcts if a is not None))
    marker_map    = {a: m for a, m in zip(unique_argons, ['o', 's', '^', 'D', 'v'])}

    for i in range(len(pca_data['samples'])):
        p      = pressures[i]
        arg    = argon_pcts[i]
        colour = pressure_cmap(pressure_norm(p)) if p is not None else COLOURS['grey']
        marker = marker_map.get(arg, 'o')

        ax2.scatter(pca_data['transformed'][i, 0],
                    pca_data['transformed'][i, 1],
                    color=colour, marker=marker, s=70, zorder=3,
                    edgecolors='#333333', linewidths=0.5)

    ax2.set_xlabel(f"PC1 ({pca_data['explained_var'][0]:.1f}%)")
    ax2.set_ylabel(f"PC2 ({pca_data['explained_var'][1]:.1f}%)")
    apply_thesis_style(ax2)

    # Pressure colourbar
    sm = cm.ScalarMappable(cmap='Blues', norm=pressure_norm)
    sm.set_array([])
    cbar = fig.colorbar(sm, ax=ax2, pad=0.02, shrink=0.8)
    cbar.set_label('Pressure (mTorr)', fontsize=9)
    cbar.ax.tick_params(labelsize=8, direction='in')
    cbar.outline.set_linewidth(0.5)

    # Argon % legend via marker shapes
    if len(unique_argons) > 1:
        handles = [
            plt.scatter([], [], marker=marker_map[a], color='#888888',
                        edgecolors='#333333', linewidths=0.5, s=50,
                        label=f'Ar {a:.0f}%')
            for a in unique_argons
        ]
        ax2.legend(handles=handles, frameon=False, fontsize=8,
                   loc='lower right', title='Argon %', title_fontsize=8)

    plt.tight_layout()
    plt.show()

    # ── Figure 2: PC1 loadings ────────────────────────────────────────
    loadings = pca_data['loadings'][0]
    labels   = pca_data['labels']
    sort_idx = np.argsort(np.abs(loadings))[::-1]
    top_n    = min(20, len(loadings))
    idx      = sort_idx[:top_n]
    top_load = loadings[idx]
    top_labs = [labels[i] for i in idx]

    fig2, ax3 = plt.subplots(figsize=(max(8, top_n * 0.55), 5))
    bar_colours = [COLOURS['blue'] if v >= 0 else COLOURS['red'] for v in top_load]
    ax3.bar(range(top_n), top_load, color=bar_colours, width=0.6)
    ax3.set_xticks(range(top_n))
    ax3.set_xticklabels(top_labs, rotation=45, ha='right', fontsize=8)
    ax3.axhline(0, color='#333333', linewidth=0.6)
    ax3.set_xlabel('Wavelength (nm)')
    ax3.set_ylabel(f"PC1 loading ({pca_data['explained_var'][0]:.1f}%)")
    apply_thesis_style(ax3)

    plt.tight_layout()
    plt.show()


# ─────────────────────────────────────────────
#  Main workflow
# ─────────────────────────────────────────────

def main():
    print("=" * 60)
    print("  Part 2 — Multi-Sample OES Analyser")
    print("=" * 60)

    if not os.path.isfile(REF_CSV):
        print(f"Reference CSV not found:\n  {REF_CSV}")
        return

    try:
        reference_peaks = load_reference_peaks_csv(REF_CSV)
    except Exception as e:
        print(f"Failed to load reference CSV: {e}")
        return

    print("\nSelect sample spectrum files to analyse.")
    root = tk.Tk(); root.withdraw(); root.attributes('-topmost', True)
    try:
        sample_files = filedialog.askopenfilenames(
            title="Select Sample OES Spectra",
            filetypes=[("Text/CSV files", "*.txt *.csv"), ("All files", "*.*")],
        )
    finally:
        root.destroy()

    if not sample_files:
        print("No sample files selected. Exiting.")
        return

    sample_files = list(sample_files)
    print(f"{len(sample_files)} sample file(s) selected.")

    print("\nAnalysis parameters")
    try:
        wavelength_tolerance = float(
            input("  Wavelength lookup tolerance in nm [default 0.1]: ") or "0.1"
        )
        wavelength_tolerance = validate_parameters(50, 10, wavelength_tolerance)[2]
    except ValueError as e:
        print(f"  {e} — using 0.1 nm tolerance.")
        wavelength_tolerance = 0.1

    results = analyse_samples_against_reference_peaks(
        reference_peaks, sample_files, wavelength_tolerance
    )

    save_q = (input("\nSave results to text file? (y/n) [y]: ").lower() or "y")
    if save_q.startswith('y'):
        root2 = tk.Tk(); root2.withdraw(); root2.attributes('-topmost', True)
        try:
            out_file = filedialog.asksaveasfilename(
                title="Save Analysis Results",
                defaultextension=".txt",
                filetypes=[("Text files", "*.txt"), ("All files", "*.*")],
            )
        finally:
            root2.destroy()
        if out_file:
            save_results(results, REF_CSV, out_file)
            print(f"Results saved -> {out_file}")

    plot_q = (input("\nGenerate plots? (y/n) [y]: ").lower() or "y")
    if plot_q.startswith('y'):
        plot_sample_spectra(results)
        plot_vib_temp_trends(results)

    pca_q = (input("\nRun PCA across samples? (y/n) [y]: ").lower() or "y")
    if pca_q.startswith('y'):
        pca_data = perform_pca(results)
        plot_pca(pca_data)

    print("\n✓ Analysis complete.")


if __name__ == "__main__":
    main()
