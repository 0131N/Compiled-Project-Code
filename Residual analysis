def process_and_plot(directory=DIRECTORY):
    files = [f for f in os.listdir(directory) if f.endswith('.txt')]

    if not files:
        print("No .txt files found in the directory.")
        return

    print(f"Found {len(files)} files. Starting analysis...\n")

    results = []

    for f in sorted(files):
        power, pressure, integ_ms, argon_pct = extract_experiment_params(f)

        if any(v is None for v in [power, pressure, argon_pct]):
            print(f"  Skipped {f}: missing power / pressure / argon% in name.")
            continue

        # optional filters
        if FILTER_PRESSURE is not None and abs(pressure - FILTER_PRESSURE) > 1.0:
            continue
        if FILTER_ARGON_MAX is not None and argon_pct > FILTER_ARGON_MAX:
            continue

        try:
            df = pd.read_csv(os.path.join(directory, f))
        except Exception as e:
            print(f"  Error loading {f}: {e}")
            continue

        # normalise by integration time so different exposures are comparable
        if integ_ms and integ_ms > 0:
            df = df.copy()
            df['cal_intensity'] = df['cal_intensity'] / integ_ms

        fps, sps, fps_sps_ratio = compute_fps_sps(df)
        ar_ratios               = compute_ar_ratios(df)
        ar_high                 = compute_ar_high(df)

        r1 = ar_ratios.get('I(811.5) / I(750.4)', np.nan)
        print(f"  Ar={argon_pct:.1f}%  {pressure:.0f} mTorr  {power:.0f}W  "
              f"t={integ_ms}ms  |  "
              f"FPS/SPS={fps_sps_ratio:.4f}  I(811)/I(750)={r1:.4f}")

        results.append({
            'file':      f,
            'power':     power,
            'pressure':  pressure,
            'integ_ms':  integ_ms,
            'argon_pct': argon_pct,
            'fps_sps':   fps_sps_ratio,
            'ar_ratios': ar_ratios,
            'ar_high':   ar_high,
            'df':        df,
        })

    if not results:
        print("\nNo valid data processed. Check filename format and DIRECTORY.")
        return

    results.sort(key=lambda r: (r['pressure'], r['power'], r['argon_pct']))
    print(f"\nProcessed {len(results)} spectra successfully.")

    # broadband overlay
    _plot_overlay(results)

    # one three-panel figure per unique (power, pressure) combination
    groups = {}
    for r in results:
        key = (r['power'], r['pressure'])
        groups.setdefault(key, []).append(r)

    for (pwr, pres), grp in sorted(groups.items()):
        grp.sort(key=lambda r: r['argon_pct'])
        if len(grp) < 2:
            continue
        _plot_trends(grp, pwr, pres)

    plt.show()


