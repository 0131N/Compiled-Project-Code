def _add_threshold(ax):
    ax.axvline(POOLING_THRESHOLD_PCT,
               color=COLOURS['grey'], lw=0.9, ls='--', alpha=0.7,
               label='Penning\u2192pooling threshold (~2\u20133%)')


def _plot_overlay(results):
    """Log-scale overlay of all broadband spectra coloured by Ar%."""
    fig, ax = plt.subplots(figsize=(12, 5))

    ar_vals = [r['argon_pct'] for r in results]
    cmap    = plt.cm.plasma
    norm    = plt.Normalize(min(ar_vals), max(ar_vals) if max(ar_vals) > 0 else 1)

    for r in results:
        df   = r['df']
        mask = (df['wavelength_nm'] >= 500) & (df['wavelength_nm'] <= 1110)
        inten = np.clip(df.loc[mask, 'cal_intensity'].values, 1e-9, None)
        ax.semilogy(df.loc[mask, 'wavelength_nm'].values, inten,
                    color=cmap(norm(r['argon_pct'])), lw=0.5, alpha=0.8)

    # mark key line positions
    for wl_c, (_, ltype) in AR_LINES.items():
        c = COLOURS['red'] if ltype == 'metastable' else COLOURS['blue']
        ax.axvline(wl_c, color=c, lw=0.35, alpha=0.35, ls='--')
    for wl_c in AR_HIGH:
        ax.axvline(wl_c, color=COLOURS['green'], lw=0.4, alpha=0.4, ls=':')
    for wl_c in FPS_BANDS.values():
        ax.axvline(wl_c, color=COLOURS['orange'], lw=0.35, alpha=0.3, ls='-.')

    sm = plt.cm.ScalarMappable(cmap=cmap, norm=norm)
    sm.set_array([])
    fig.colorbar(sm, ax=ax, label='Argon (%)')

    from matplotlib.lines import Line2D
    ax.legend(handles=[
        Line2D([0],[0], color=COLOURS['red'],    lw=1, ls='--',
               label='Ar I metastable-terminating'),
        Line2D([0],[0], color=COLOURS['blue'],   lw=1, ls='--',
               label='Ar I resonant-terminating'),
        Line2D([0],[0], color=COLOURS['green'],  lw=1, ls=':',
               label='Ar** high-lying'),
        Line2D([0],[0], color=COLOURS['orange'], lw=1, ls='-.',
               label='N$_2$ FPS band heads'),
    ], frameon=False, fontsize=8, loc='upper right')

    ax.set_xlabel('Wavelength (nm)')
    ax.set_ylabel('Calibrated intensity / ms  (log scale)')
    apply_thesis_style(ax)
    plt.tight_layout()
    plt.savefig('broadband_overlay.png', dpi=150)


def _plot_trends(grp, power, pressure):
    """
    Three-panel figure for a single (power, pressure) condition:
      Panel 1 — FPS/SPS ratio vs Ar%
      Panel 2 — Ar NIR metastable/resonant ratios vs Ar%
      Panel 3 — High-lying Ar** intensities vs Ar%
    """
    ar    = np.array([r['argon_pct'] for r in grp])
    label = f'{power:.0f} W,  {pressure:.0f} mTorr'

    fig, axes = plt.subplots(3, 1, figsize=(8, 12))
    fig.suptitle('Broadband corroboration of Penning-to-pooling mechanism\n'
                 + label, fontsize=11, y=1.01)

    # ── Panel 1: FPS / SPS ───────────────────────────────────────────────────
    ax = axes[0]
    fps_sps = np.array([r['fps_sps'] for r in grp])
    ax.plot(ar, fps_sps, 'o-',
            color=COLOURS['orange'], linewidth=1.5, markersize=6,
            label='FPS / SPS')
    _add_threshold(ax)
    ax.set_xlabel('Argon concentration (%)')
    ax.set_ylabel('FPS / SPS integrated intensity')
    ax.legend(frameon=False, fontsize=9)
    apply_thesis_style(ax)

    # ── Panel 2: Ar NIR ratios ───────────────────────────────────────────────
    ax = axes[1]
    ratio_labels = list(grp[0]['ar_ratios'].keys())
    for idx, lbl in enumerate(ratio_labels):
        vals  = np.array([r['ar_ratios'].get(lbl, np.nan) for r in grp])
        valid = ~np.isnan(vals)
        if valid.sum() < 2:
            continue
        ax.plot(ar[valid], vals[valid], 'o-',
                color=COLOUR_LIST[idx % len(COLOUR_LIST)],
                linewidth=1.5, markersize=6, label=lbl)
    _add_threshold(ax)
    ax.set_xlabel('Argon concentration (%)')
    ax.set_ylabel('Metastable / resonant line ratio')
    ax.legend(frameon=False, fontsize=8, loc='upper left')
    apply_thesis_style(ax)

    # ── Panel 3: High-lying Ar** ─────────────────────────────────────────────
    ax      = axes[2]
    wl_list = sorted(AR_HIGH.keys())
    ref_idx = 0   # normalise to lowest Ar% value

    for j, wl_c in enumerate(wl_list):
        vals    = np.array([r['ar_high'].get(wl_c, 0.0) for r in grp])
        ref_val = vals[ref_idx] if vals[ref_idx] > 0 else 1.0
        vals_n  = vals / ref_val
        ax.plot(ar, vals_n, 'o-',
                color=COLOUR_LIST[(j + 3) % len(COLOUR_LIST)],
                linewidth=1.5, markersize=6,
                label=f'{wl_c:.0f} nm')

    ax.axhline(1.0, color=COLOURS['grey'], lw=0.6, ls=':', alpha=0.6)
    _add_threshold(ax)
    ax.set_xlabel('Argon concentration (%)')
    ax.set_ylabel('Intensity / intensity at lowest Ar%')
    ax.legend(frameon=False, fontsize=8, loc='upper left')
    apply_thesis_style(ax)

    plt.tight_layout()
    safe = f"{power:.0f}W_{pressure:.0f}mTorr"
    plt.savefig(f'pooling_{safe}.png', dpi=150, bbox_inches='tight')


