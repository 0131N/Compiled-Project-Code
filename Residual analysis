#  Filename parsing — matches existing code style
# ─────────────────────────────────────────────

def extract_experiment_params(filename):
    """
    Extracts Power, Pressure, integration time, and argon% from filename.

    Handles the R26B naming convention, e.g.:
      Nitrogen_31_8_argon_3_2_10mTorr_70W_vs_35W_ref_300ms_HRC21401_...txt

    For filenames with two power values (e.g. 70W_vs_35W_ref), the FIRST
    power value found is taken as the actual plasma power.

    Returns: (power_W, pressure_mTorr, integ_time_ms, argon_pct)
             Any value is None if not found in the filename.
    """
    base = os.path.basename(filename)

    # Power — first match only (actual power, not reference power)
    power_match = re.search(r'(\d+\.?\d*)\s*W', base, re.IGNORECASE)
    power = float(power_match.group(1)) if power_match else None

    # Pressure
    pressure_match = re.search(r'(\d+\.?\d*)\s*mTorr', base, re.IGNORECASE)
    pressure = float(pressure_match.group(1)) if pressure_match else None

    # Integration time
    time_match = re.search(r'(\d+)\s*ms', base, re.IGNORECASE)
    integ_ms = float(time_match.group(1)) if time_match else None

    # Argon percentage
    # argon_X_Y  →  X.Y%   (e.g. argon_3_2 = 3.2%)
    # argon_X    →  X%     (e.g. argon_9   = 9.0%)
    # pure / pureN2 → 0%
    fname_lower = base.lower()
    ar_decimal  = re.search(r'argon[_\s](\d+)[_\s](\d)(?!\d)', fname_lower)
    ar_integer  = re.search(r'argon[_\s](\d+)(?:[_\s]|$)',     fname_lower)

    if ar_decimal:
        argon_pct = float(f"{ar_decimal.group(1)}.{ar_decimal.group(2)}")
    elif ar_integer:
        argon_pct = float(ar_integer.group(1))
    elif 'pure' in fname_lower:
        argon_pct = 0.0
    else:
        argon_pct = None

    return power, pressure, integ_ms, argon_pct


# ─────────────────────────────────────────────
#  Spectral integration
# ─────────────────────────────────────────────

def integrate_line(df, centre_nm, window_nm=INTEGRATION_WINDOW_NM):
    """
    Baseline-subtracted integrated intensity within ±window_nm of centre_nm.
    Uses cal_intensity column (already wavelength-calibrated).
    Returns 0.0 if the line is outside the spectral range.
    """
    lo = centre_nm - window_nm * 2.5
    hi = centre_nm + window_nm * 2.5
    region = df[(df['wavelength_nm'] >= lo) & (df['wavelength_nm'] <= hi)]

    if len(region) < 4:
        return 0.0

    wl    = region['wavelength_nm'].values
    inten = np.clip(region['cal_intensity'].values, 0, None)

    # linear baseline from edge points
    n_edge   = max(1, int(len(wl) * 0.18))
    bsl_x    = np.concatenate([wl[:n_edge], wl[-n_edge:]])
    bsl_y    = np.concatenate([inten[:n_edge], inten[-n_edge:]])
    coeffs   = np.polyfit(bsl_x, bsl_y, 1) if len(bsl_x) >= 2 \
               else np.array([0.0, float(np.mean(bsl_y))])
    baseline = np.polyval(coeffs, wl)

    # integrate core window only
    core = (wl >= centre_nm - window_nm) & (wl <= centre_nm + window_nm)
    if core.sum() < 2:
        return 0.0

    net = np.clip(inten[core] - baseline[core], 0, None)
    return float(trapezoid(net, wl[core]))


def compute_fps_sps(df):
    fps = sum(integrate_line(df, c) for c in FPS_BANDS.values())
    sps = sum(integrate_line(df, c) for c in SPS_BANDS.values())
    return fps, sps, (fps / sps if sps > 0 else np.nan)


def compute_ar_ratios(df):
    intensities = {c: integrate_line(df, c) for c in AR_LINES}
    ratios = {}
    for wm, wr, lbl in RATIO_PAIRS:
        im = intensities.get(wm, 0.0)
        ir = intensities.get(wr, 0.0)
        ratios[lbl] = im / ir if ir > 0 else np.nan
    return ratios


def compute_ar_high(df):
    return {c: integrate_line(df, c) for c in AR_HIGH}


