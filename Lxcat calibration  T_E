import numpy as np
import matplotlib.pyplot as plt
from scipy.optimize import curve_fit

# --- Publication Style ---
def apply_thesis_style(ax):
    ax.spines['top'].set_visible(False)
    ax.spines['right'].set_visible(False)
    ax.spines['left'].set_linewidth(0.8)
    ax.spines['bottom'].set_linewidth(0.8)
    ax.tick_params(axis='both', direction='in', length=4, width=0.8, top=False, right=False)
    ax.grid(False)

def load_cross_section(filepath):
    energies, cross_sections = [], []
    try:
        with open(filepath, 'r') as f:
            for line in f:
                parts = line.split()
                if len(parts) == 2:
                    try:
                        energies.append(float(parts[0]))
                        cross_sections.append(float(parts[1]))
                    except ValueError: pass
    except FileNotFoundError:
        print(f"Error: {filepath} not found.")
    return np.array(energies), np.array(cross_sections)

def calculate_rate_coefficient(energies, cross_sections, Te):
    """Integrates cross section over a Maxwellian EEDF."""
    integrand = cross_sections * energies * np.exp(-energies / Te)
    return np.trapezoid(integrand, energies)

# --- 1. Load and Scale ---
E_neu, xs_neu = load_cross_section('Cross section Excitation.txt')
E_ion, xs_ion = load_cross_section('Cross section Ion.txt')
xs_neu = xs_neu * 0.67  # Rescaling factor

# --- 2. Generate Theoretical Curve ---
Te_range = np.linspace(1.5, 8.0, 100)
theoretical_ratios = []
for Te in Te_range:
    k_neu = calculate_rate_coefficient(E_neu, xs_neu, Te)
    k_ion = calculate_rate_coefficient(E_ion, xs_ion, Te)
    theoretical_ratios.append(k_ion / k_neu if k_neu > 0 else 0)
theoretical_ratios = np.array(theoretical_ratios)

# --- 3. Calibration ---
reference_Te = 5.0
reference_meas_ratio = 1  # Using error propagation, can be calibrated from probe
theo_ratio_ref = calculate_rate_coefficient(E_ion, xs_ion, reference_Te) / \
                 calculate_rate_coefficient(E_neu, xs_neu, reference_Te)
C = reference_meas_ratio / theo_ratio_ref
calibrated_ratios = theoretical_ratios * C

# --- 4. Arrhenius Fit ---
delta_E = 18.8 - 11.03
def arrhenius_model(Te, A):
    return A * np.exp(-delta_E / Te)

popt, _ = curve_fit(arrhenius_model, Te_range, calibrated_ratios)
A_final = popt[0]
ln_A = np.log(A_final)

# --- 5. Visualize ---
fig, ax = plt.subplots(figsize=(6, 4.5))
ax.plot(Te_range, calibrated_ratios, 'b-', linewidth=1.5, label='Calibrated LXCat')
ax.plot(Te_range, arrhenius_model(Te_range, A_final), 'r--', linewidth=1.2, label='Arrhenius Fit')
ax.scatter(reference_Te, reference_meas_ratio, color='black', marker='*', s=100, label='Ref Point', zorder=5)

ax.set_xlabel('Electron Temperature $T_e$ (eV)')
ax.set_ylabel('Intensity Ratio (391nm / 380nm)')

ax.legend(frameon=False)
apply_thesis_style(ax)

plt.tight_layout()
plt.show()

print("-" * 30)
print(f"CALIBRATION SUCCESSFUL")
print(f"Optical Factor (C): {C:.4f}")
print(f"Pre-exponential (A): {A_final:.4f}")
print(f"USE THIS ln_A IN MAIN CODE: {ln_A:.4f}")
print("-" * 30)
