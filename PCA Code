#Data Collection
def get_integration_time(filename):

    base_name = os.path.basename(filename)
    
 
    match = re.search(r'(\d{2,3})ms', base_name)
    
    if match:
        time_val = float(match.group(1))
        return time_val
    return None
def extract_experiment_params(filename):
    """Extracts Power (W) and Pressure (mTorr) from filename."""
    base_name = os.path.basename(filename)
    
    # Regex for Power (e.g., "50W", "50.5 W")
    power_match = re.search(r'(\d+\.?\d*)\s*W', base_name, re.IGNORECASE)
    power = float(power_match.group(1)) if power_match else None
    
    # Regex for Pressure (e.g., "100mTorr", "100 mTorr")
    pressure_match = re.search(r'(\d+\.?\d*)\s*mTorr', base_name, re.IGNORECASE)
    pressure = float(pressure_match.group(1)) if pressure_match else None
    
    return power, pressure
def load_oes_data(filename):
    
    try:
        # Try multiple methods to load the file
        methods = [
            # Method 1: Try pandas with flexible parsing
            lambda f: pd.read_csv(f, sep='\t|,|\s+', engine='python', header=None).values,
            # Method 2: Try numpy with skipping headers
            lambda f: np.loadtxt(f, skiprows=1),
            # Method 3: Try numpy with comments
            lambda f: np.loadtxt(f, comments=['#', 'Data', 'Wavelength']),
            # Method 4: Try manual parsing
            lambda f: load_oes_data_manual(f)
        ]
        
        data = None
        for i, method in enumerate(methods):
            try:
                data = method(filename)
                print(f"Successfully loaded with method {i+1}")
                break
            except Exception as e:
                continue
        
        if data is None:
             raise ValueError("All loading methods failed")
        
        if data.ndim == 1:
            wavelength = np.arange(len(data))
            intensity = data
        else:
            if data.shape[1] < 1:
                raise ValueError("File must have at least one column for intensity")
            elif data.shape[1] == 1:
                wavelength = np.arange(len(data))
                intensity = data[:, 0]
            else:
                wavelength = data[:, 0]
                intensity = data[:, 1]
        
        print(f"Loaded data: {len(wavelength)} points, wavelength range: {wavelength[0]:.1f}-{wavelength[-1]:.1f} nm")
        return wavelength, intensity
        
    except Exception as e:
        print(f"Error loading file {filename}: {str(e)}")
        # Try one more time with manual parsing as last resort
        try:
            return load_oes_data_manual(filename)
        except:
            return None, None

def load_oes_data_manual(filename):
    #manual parsing
    wavelengths = []
    intensities = []
    
    with open(filename, 'r', encoding='utf-8', errors='ignore') as f:
        lines = f.readlines()
    
    
    data_started = False
    for line in lines:
        line = line.strip()
        
        # Skip empty lines and header lines
        if not line or any(keyword in line for keyword in ['Data', 'Wavelength', 'Intensity', 'nm', '#']):
            continue
        
        # split and parse numbers
        parts = line.split()
        if len(parts) >= 2:
            try:
                wl = float(parts[0])
                intensity = float(parts[1])
                wavelengths.append(wl)
                intensities.append(intensity)
                data_started = True
            except ValueError:
                if data_started:
                 
                    break
                continue
    
    if not wavelengths:
        raise ValueError("No numeric data found in file")
    
    return np.array(wavelengths), np.array(intensities)

def load_oes_data_simple(filename): #use this function to select files
   
    try:
        
        with open(filename, 'r') as f:
            lines = f.readlines()
        
        # Start of Numbers
        data_lines = []
        for line in lines:
            line = line.strip()
            if not line:
                continue
            
            # Check if line starts with numeric data
            parts = line.split()
            if len(parts) >= 2:
                try:
                    float(parts[0])
                    float(parts[1])
                    data_lines.append(line)
                except ValueError:
                    continue  # Skip non-numeric lines
        #Hi :)
        if not data_lines:
            raise ValueError("No numeric data found")
        
   
        data = []
        for line in data_lines:
            parts = line.split()
            if len(parts) >= 2:
                try:
                    row = [float(parts[0]), float(parts[1])]
                    data.append(row)
                except ValueError:
                    continue
        
        data = np.array(data)
        
        if data.ndim == 1:
            wavelength = np.arange(len(data))
            intensity = data
        else:
            wavelength = data[:, 0]
            intensity = data[:, 1]
        
        print(f"Loaded {len(wavelength)} data points")
        return wavelength, intensity
        
    except Exception as e:
        print(f"Error in simple loader for {filename}: {str(e)}")
        return None, None

