import pandas as pd

def load_oes_data(filename):
    """Load OES data from various file formats including OceanView exports"""
    try:
        # Try multiple methods to load the file
        methods = [
            # Method 1: Try pandas with flexible parsing
            lambda f: pd.read_csv(f, sep='\t|,|\s+', engine='python', header=None).values,
            # Method 2: Try numpy with skipping headers
            lambda f: np.loadtxt(f, skiprows=1),
            # Method 3: Try numpy with comments
            lambda f: np.loadtxt(f, comments=['#', 'Data', 'Wavelength']),
            # Method 4: Try manual parsing
            lambda f: load_oes_data_manual(f)
        ]
        
        for i, method in enumerate(methods):
            try:
                data = method(filename)
                print(f"Successfully loaded with method {i+1}")
                break
            except Exception as e:
                continue
        else:
            raise ValueError("All loading methods failed")
        
        if data.ndim == 1:
            wavelength = np.arange(len(data))
            intensity = data
        else:
            if data.shape[1] < 1:
                raise ValueError("File must have at least one column for intensity")
            elif data.shape[1] == 1:
                wavelength = np.arange(len(data))
                intensity = data[:, 0]
            else:
                wavelength = data[:, 0]
                intensity = data[:, 1]
        
        print(f"Loaded data: {len(wavelength)} points, wavelength range: {wavelength[0]:.1f}-{wavelength[-1]:.1f} nm")
        return wavelength, intensity
        
    except Exception as e:
        print(f"Error loading file {filename}: {str(e)}")
        # Try one more time with manual parsing as last resort
        try:
            return load_oes_data_manual(filename)
        except:
            return None, None

def load_oes_data_manual(filename):
    """Manual parsing for difficult OceanView files"""
    wavelengths = []
    intensities = []
    
    with open(filename, 'r', encoding='utf-8', errors='ignore') as f:
        lines = f.readlines()
    
    # Find data section
    data_started = False
    for line in lines:
        line = line.strip()
        
        # Skip empty lines and header lines
        if not line or any(keyword in line for keyword in ['Data', 'Wavelength', 'Intensity', 'nm', '#']):
            continue
        
        # Try to split and parse numbers
        parts = line.split()
        if len(parts) >= 2:
            try:
                wl = float(parts[0])
                intensity = float(parts[1])
                wavelengths.append(wl)
                intensities.append(intensity)
                data_started = True
            except ValueError:
                if data_started:
                    # If we already started data, this might be the end
                    break
                continue
    
    if not wavelengths:
        raise ValueError("No numeric data found in file")
    
    return np.array(wavelengths), np.array(intensities)

def load_oes_data_simple(filename):
    """Simplified loader that handles headers and non-numeric data"""
    try:
        # Read all lines
        with open(filename, 'r') as f:
            lines = f.readlines()
        
        # Find where numeric data starts
        data_lines = []
        for line in lines:
            line = line.strip()
            if not line:
                continue
            
            # Check if line starts with numeric data
            parts = line.split()
            if len(parts) >= 2:
                try:
                    float(parts[0])
                    float(parts[1])
                    data_lines.append(line)
                except ValueError:
                    continue  # Skip non-numeric lines
        
        if not data_lines:
            raise ValueError("No numeric data found")
        
        # Parse the numeric data
        data = []
        for line in data_lines:
            parts = line.split()
            if len(parts) >= 2:
                try:
                    row = [float(parts[0]), float(parts[1])]
                    data.append(row)
                except ValueError:
                    continue
        
        data = np.array(data)
        
        if data.ndim == 1:
            wavelength = np.arange(len(data))
            intensity = data
        else:
            wavelength = data[:, 0]
            intensity = data[:, 1]
        
        print(f"Loaded {len(wavelength)} data points")
        return wavelength, intensity
        
    except Exception as e:
        print(f"Error in simple loader for {filename}: {str(e)}")
        return None, None

def clean_string_for_filename(filename):
    """Clean string for filename display"""
    return os.path.basename(filename)

def validate_parameters(min_height, min_distance, wavelength_tolerance):
    """Validate user input parameters"""
    if min_height < 0:
        raise ValueError("Minimum height must be non-negative")
    if min_distance < 1:
        raise ValueError("Minimum distance must be at least 1")
    if wavelength_tolerance < 0:
        raise ValueError("Wavelength tolerance must be non-negative")
    return min_height, min_distance, wavelength_tolerance

def estimate_detection_limits(intensity, noise_multiplier=3):
    """Estimate detection limits based on noise level"""
    # Use the first 50 points or 10% of data (whichever is smaller) for noise estimation
    n_points = min(50, len(intensity) // 10)
    if n_points < 5:
        n_points = len(intensity) // 4
    
    noise_std = np.std(intensity[:n_points])
    return noise_multiplier * noise_std

def normalize_spectrum(intensity, method='max'):
    """Normalize spectrum intensity"""
    if method == 'max':
        return intensity / np.max(intensity)
    elif method == 'area':
        return intensity / np.trapz(intensity)
    else:
        return intensity

def find_oes_peaks(wavelength, intensity, min_height=5000, min_distance=10, prominence=None):
    """
    Identify peaks in OES data with automatic prominence estimation
    """
    # Auto-calculate prominence if not provided
    if prominence is None:
        prominence = estimate_detection_limits(intensity, noise_multiplier=5)
    
    peaks, properties = scipy.signal.find_peaks(
        intensity, 
        height=min_height,
        distance=min_distance,
        prominence=prominence,
        width=2
    )
    
    peak_wavelengths = wavelength[peaks]
    peak_intensities = intensity[peaks]
    
    return peak_wavelengths, peak_intensities, properties

def get_intensity_at_wavelength(wavelength_array, intensity_array, target_wavelength, tolerance=0.1):
    """
    Get intensity value at or near a specific wavelength
    Returns intensity at the closest wavelength point within tolerance
    """
    # Find the closest wavelength point
    wavelength_diffs = np.abs(wavelength_array - target_wavelength)
    min_diff_index = np.argmin(wavelength_diffs)
    min_diff = wavelength_diffs[min_diff_index]
    
    if min_diff <= tolerance:
        return intensity_array[min_diff_index], min_diff
    else:
        return 0, min_diff  # Return 0 if no point within tolerance

def analyze_multiple_spectra_at_reference_peaks(reference_file, sample_files, min_height=5000, min_distance=10, wavelength_tolerance=0.1):
    """
    Analyze multiple spectra at the peak positions found in reference spectrum
    """
    # Load reference data and find peaks
    print(f"Loading reference spectrum: {clean_string_for_filename(reference_file)}")
    ref_wavelength, ref_intensity = load_oes_data_simple(reference_file)
    if ref_wavelength is None:
        print("Error loading reference file, trying alternative method...")
        ref_wavelength, ref_intensity = load_oes_data_manual(reference_file)
    
    if ref_wavelength is None:
        print("Failed to load reference file with all methods")
        return None
    
    # Find peaks in reference spectrum
    ref_peak_wavelengths, ref_peak_intensities, _ = find_oes_peaks(
        ref_wavelength, ref_intensity, min_height, min_distance
    )
    
    print(f"Found {len(ref_peak_wavelengths)} peaks in reference spectrum")
    
    # Store results
    results = {
        'reference_file': reference_file,
        'reference_wavelength': ref_wavelength,
        'reference_intensity': ref_intensity,
        'reference_peaks': list(zip(ref_peak_wavelengths, ref_peak_intensities)),
        'sample_results': {}
    }
    
    # Analyze each sample file
    for sample_file in sample_files:
        print(f"Analyzing sample: {clean_string_for_filename(sample_file)}")
        sample_wavelength, sample_intensity = load_oes_data_simple(sample_file)
        
        if sample_wavelength is None:
            print(f"Trying alternative method for: {clean_string_for_filename(sample_file)}")
            sample_wavelength, sample_intensity = load_oes_data_manual(sample_file)
        
        if sample_wavelength is None:
            print(f"Error loading sample file: {sample_file}")
            continue
        
        sample_peak_data = []
        
        # For each reference peak, find intensity in sample spectrum
        for ref_wl, ref_int in zip(ref_peak_wavelengths, ref_peak_intensities):
            sample_int, wavelength_diff = get_intensity_at_wavelength(
                sample_wavelength, sample_intensity, ref_wl, wavelength_tolerance
            )
            
            # Calculate intensity ratio (sample/reference)
            intensity_ratio = sample_int / ref_int if ref_int > 0 else 0
            
            sample_peak_data.append({
                'wavelength': ref_wl,
                'reference_intensity': ref_int,
                'sample_intensity': sample_int,
                'intensity_ratio': intensity_ratio,
                'wavelength_difference': wavelength_diff,
                'within_tolerance': wavelength_diff <= wavelength_tolerance
            })
        
        results['sample_results'][sample_file] = {
            'peak_data': sample_peak_data,
            'wavelength': sample_wavelength,
            'intensity': sample_intensity
        }
    
    return results

def save_reference_peak_analysis(results, output_file):
    """Save reference peak analysis results to file"""
    with open(output_file, 'w') as f:
        f.write("REFERENCE PEAK ANALYSIS RESULTS\n")
        f.write("=" * 60 + "\n")
        f.write(f"Reference file: {results['reference_file']}\n")
        f.write(f"Number of reference peaks: {len(results['reference_peaks'])}\n")
        f.write(f"Analysis date: {np.datetime64('now')}\n\n")
        
        # Write reference peaks
        f.write("REFERENCE PEAKS\n")
        f.write("-" * 60 + "\n")
        for i, (wl, inten) in enumerate(results['reference_peaks'], 1):
            f.write(f"Peak {i}: Wavelength = {wl:.4f} nm, Intensity = {inten:.2f}\n")
        f.write("\n")
        
        # Write results for each sample
        for sample_file, sample_data in results['sample_results'].items():
            f.write(f"SAMPLE: {clean_string_for_filename(sample_file)}\n")
            f.write("-" * 60 + "\n")
            
            for i, peak in enumerate(sample_data['peak_data'], 1):
                status = "✓" if peak['within_tolerance'] else "✗"
                f.write(f"Peak {i}: {peak['wavelength']:.4f} nm {status}\n")
                f.write(f"  Reference intensity: {peak['reference_intensity']:.2f}\n")
                f.write(f"  Sample intensity:    {peak['sample_intensity']:.2f}\n")
                f.write(f"  Intensity ratio:     {peak['intensity_ratio']:.4f}\n")
                f.write(f"  Wavelength diff:     {peak['wavelength_difference']:.4f} nm\n")
                f.write(f"  Within tolerance:    {'Yes' if peak['within_tolerance'] else 'No'}\n\n")
            
            f.write("\n")
        
        # Summary statistics
        f.write("SUMMARY STATISTICS\n")
        f.write("-" * 60 + "\n")
        for sample_file, sample_data in results['sample_results'].items():
            total_peaks = len(sample_data['peak_data'])
            peaks_in_tolerance = sum(1 for p in sample_data['peak_data'] if p['within_tolerance'])
            valid_ratios = [p['intensity_ratio'] for p in sample_data['peak_data'] if p['within_tolerance'] and p['reference_intensity'] > 0]
            avg_intensity_ratio = np.mean(valid_ratios) if valid_ratios else 0
            
            f.write(f"{clean_string_for_filename(sample_file)}:\n")
            f.write(f"  Peaks within tolerance: {peaks_in_tolerance}/{total_peaks} ({peaks_in_tolerance/total_peaks:.1%})\n")
            f.write(f"  Average intensity ratio: {avg_intensity_ratio:.4f}\n\n")

def plot_reference_peak_analysis(results):
    """Plot the reference peak analysis results"""
    n_samples = len(results['sample_results'])
    
    if n_samples == 0:
        print("No sample data to plot")
        return
    
    # Create figure with subplots
    fig, axes = plt.subplots(n_samples + 1, 1, figsize=(12, 4 * (n_samples + 1)))
    if n_samples == 0:
        axes = [axes]
    elif n_samples == 1:
        axes = [axes] if not hasattr(axes, '__len__') else axes
    
    # Plot reference spectrum
    ref_wavelength = results['reference_wavelength']
    ref_intensity = results['reference_intensity']
    ref_peaks = results['reference_peaks']
    ref_peak_wls = [p[0] for p in ref_peaks]
    ref_peak_ints = [p[1] for p in ref_peaks]
    
    axes[0].plot(ref_wavelength, ref_intensity, 'b-', linewidth=1, label='Reference Spectrum')
    axes[0].plot(ref_peak_wls, ref_peak_ints, 'ro', markersize=6, label=f'Reference Peaks ({len(ref_peaks)})')
    axes[0].set_xlabel('Wavelength (nm)')
    axes[0].set_ylabel('Intensity')
    axes[0].set_title(f'Reference Spectrum: {clean_string_for_filename(results["reference_file"])}')
    axes[0].legend()
    axes[0].grid(True, alpha=0.3)
    
    # Annotate reference peaks
    for wl, inten in ref_peaks:
        axes[0].annotate(f'{wl:.1f}', (wl, inten), 
                        xytext=(5, 5), textcoords='offset points', 
                        fontsize=8, alpha=0.7)
    
    # Plot sample spectra with reference peak positions
    for idx, (sample_file, sample_data) in enumerate(results['sample_results'].items(), 1):
        if idx >= len(axes):
            break
            
        ax = axes[idx]
        wavelength = sample_data['wavelength']
        intensity = sample_data['intensity']
        peak_data = sample_data['peak_data']
        
        ax.plot(wavelength, intensity, 'g-', linewidth=1, label='Sample Spectrum')
        
        # Plot reference peak positions on sample spectrum
        sample_ints = [p['sample_intensity'] for p in peak_data]
        ref_peak_wls = [p['wavelength'] for p in peak_data]
        ax.plot(ref_peak_wls, sample_ints, 'ro', markersize=6, 
                label=f'Reference Peak Intensities ({len(ref_peak_wls)})')
        
        ax.set_xlabel('Wavelength (nm)')
        ax.set_ylabel('Intensity')
        ax.set_title(f'Sample: {clean_string_for_filename(sample_file)}')
        ax.legend()
        ax.grid(True, alpha=0.3)
        
        # Annotate intensities at reference peak positions
        for i, (wl, sample_int) in enumerate(zip(ref_peak_wls, sample_ints)):
            ax.annotate(f'{sample_int:.0f}', (wl, sample_int), 
                       xytext=(5, 5), textcoords='offset points', 
                       fontsize=8, alpha=0.7, color='red')
    
    plt.tight_layout()
    plt.show()

def get_file_paths_dialog():
    """Get file paths using tkinter dialog"""
    root = tk.Tk()
    root.withdraw()
    root.attributes('-topmost', True)
    
    try:
        # Select reference file
        print("Select REFERENCE OES spectrum file...")
        reference_file = filedialog.askopenfilename(
            title="Select Reference OES Spectrum",
            filetypes=[("Text files", "*.txt"), ("CSV files", "*.csv"), ("All files", "*.*")]
        )
        
        if not reference_file:
            print("No reference file selected")
            return None, None
        
        # Select multiple sample files
        print("Select SAMPLE OES spectrum files to analyze...")
        sample_files = filedialog.askopenfilenames(
            title="Select Sample OES Spectra",
            filetypes=[("Text files", "*.txt"), ("CSV files", "*.csv"), ("All files", "*.*")]
        )
        
        if not sample_files:
            print("No sample files selected")
            return None, None
            
        return reference_file, list(sample_files)
        
    except Exception as e:
        print(f"Error in file dialog: {e}")
        return None, None
    finally:
        try:
            root.destroy()
        except:
            pass

def reference_peak_analysis():
    """Main function for reference peak analysis"""
    print("\n=== REFERENCE PEAK ANALYSIS ===")
    print("This mode uses the first spectrum as reference and checks")
    print("intensities at reference peak positions in other spectra.")
    
    # Get file paths
    reference_file, sample_files = get_file_paths_dialog()
    
    if reference_file is None or sample_files is None:
        print("File selection cancelled or failed.")
        return
    
    print(f"Reference file: {clean_string_for_filename(reference_file)}")
    print(f"Sample files: {len(sample_files)} files selected")
    
    # Get analysis parameters
    try:
        min_height = float(input("Enter minimum peak height for reference (default 5000): ") or "5000")
        min_distance = int(input("Enter minimum peak distance in data points (default 10): ") or "10")
        wavelength_tolerance = float(input("Enter wavelength tolerance for intensity lookup (default 0.1): ") or "0.1")
        
        min_height, min_distance, wavelength_tolerance = validate_parameters(
            min_height, min_distance, wavelength_tolerance
        )
    except ValueError as e:
        print(f"Parameter error: {e}. Using default parameters.")
        min_height = 5000
        min_distance = 10
        wavelength_tolerance = 0.1
    
    # Perform analysis
    results = analyze_multiple_spectra_at_reference_peaks(
        reference_file, sample_files, min_height, min_distance, wavelength_tolerance
    )
    
    if results is None:
        print("Analysis failed.")
        return
    
    # Print results
    print("\n" + "="*70)
    print("REFERENCE PEAK ANALYSIS RESULTS")
    print("="*70)
    
    print(f"\nReference: {clean_string_for_filename(reference_file)}")
    print(f"Found {len(results['reference_peaks'])} peaks in reference spectrum:")
    
    for i, (wl, inten) in enumerate(results['reference_peaks'], 1):
        print(f"  {i}. {wl:.4f} nm (Intensity: {inten:.2f})")
    
    # Print results for each sample
    for sample_file, sample_data in results['sample_results'].items():
        print(f"\n--- {clean_string_for_filename(sample_file)} ---")
        peak_data = sample_data['peak_data']
        
        peaks_in_tolerance = sum(1 for p in peak_data if p['within_tolerance'])
        print(f"Peaks within tolerance: {peaks_in_tolerance}/{len(peak_data)}")
        
        for i, peak in enumerate(peak_data, 1):
            status = "✓" if peak['within_tolerance'] else "✗"
            print(f"  {i}. {peak['wavelength']:.4f} nm {status}")
            print(f"     Ref: {peak['reference_intensity']:.2f}, Sample: {peak['sample_intensity']:.2f}")
            print(f"     Ratio: {peak['intensity_ratio']:.4f}, Wavelength diff: {peak['wavelength_difference']:.4f} nm")
    
    # Ask to save results
    save_results = input("\nSave results to file? (y/n, default=y): ").lower() or "y"
    if save_results.startswith('y'):
        root = tk.Tk()
        root.withdraw()
        output_file = filedialog.asksaveasfilename(
            title="Save Reference Peak Analysis Results",
            defaultextension=".txt",
            filetypes=[("Text files", "*.txt"), ("All files", "*.*")]
        )
        if output_file:
            save_reference_peak_analysis(results, output_file)
            print(f"Results saved to {output_file}")
    
    # Ask to plot results
    plot_results = input("\nPlot results? (y/n, default=y): ").lower() or "y"
    if plot_results.startswith('y'):
        print("Generating plots...")
        plot_reference_peak_analysis(results)

def main():
    """Main function"""
    print("OES Spectrum Reference Peak Analysis Tool")
    print("=" * 50)
    print("This tool analyzes multiple spectra at the peak positions")
    print("identified in a reference spectrum.")
    
    reference_peak_analysis()
    
    print("\nAnalysis complete!")

if __name__ == "__main__":
    main()
