def get_peak_intensity(wavelength_array, intensity_array, target_wl, tolerance=1.0):
    
    mask = (wavelength_array >= target_wl - tolerance) & (wavelength_array <= target_wl + tolerance)
    
    if not np.any(mask):
        return 0.0 # Wavelength not found
        
    # Get the max intensity in that specific region
    local_intensities = intensity_array[mask]
    return np.max(local_intensities)

def calculate_vibrational_temperature(wavelength, intensity):
  
    # 1. Get the intensity at the specific wavelengths
    # We look within +/- 1.0 nm to account for spectrometer calibration shifts
    I_00 = get_peak_intensity(wavelength, intensity, 337.13, tolerance=1.0)
    I_10 = get_peak_intensity(wavelength, intensity, 315.93, tolerance=1.0)
    
    # 2. Check for bad data (avoid division by zero or log of zero)
    if I_00 <= 0 or I_10 <= 0:
        return None # Cannot calculate temp if peaks are missing
        
  
