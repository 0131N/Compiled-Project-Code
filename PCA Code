def normalize_spectrum(intensity, method='max'):
    
    if method == 'max':
        return intensity / np.max(intensity)
    elif method == 'area':
        return intensity / np.trapz(intensity)
    else:
        return intensity
# Finds initial peaks seperate by a min distance.
def find_oes_peaks(wavelength, intensity, min_height=5000, min_distance=10, prominence=None):
   
    
    #if prominence is None:
        #prominence = estimate_detection_limits(intensity, noise_multiplier=5)
    
    peaks, properties = scipy.signal.find_peaks(
        intensity, 
        height=min_height,
        distance=min_distance,
        prominence=prominence,
        width=2
    )
    
    peak_wavelengths = wavelength[peaks]
    peak_intensities = intensity[peaks]
    
    return peak_wavelengths, peak_intensities, properties

# This function does the actual wavelength scanning using the tolerance as a standard deviation.
def get_intensity_at_wavelength(wavelength_array, intensity_array, target_wavelength, tolerance=0.1):
    
    
    wavelength_diffs = np.abs(wavelength_array - target_wavelength)
    min_diff_index = np.argmin(wavelength_diffs)
    min_diff = wavelength_diffs[min_diff_index]
    
    if min_diff <= tolerance:
        return intensity_array[min_diff_index], min_diff
    else:
        return 0, min_diff  # Return 0 if no point within tolerance

def analyze_multiple_spectra_at_reference_peaks(reference_file, sample_files, min_height=5000, min_distance=10, wavelength_tolerance=0.1):
    
 
    print(f"Loading reference spectrum: {clean_string_for_filename(reference_file)}")
    ref_wavelength, ref_intensity = load_oes_data_simple(reference_file)
    if ref_wavelength is None:
        print("Error loading reference file, trying alternative method...")
        ref_wavelength, ref_intensity = load_oes_data_manual(reference_file)
    
    if ref_wavelength is None:
        print("Failed to load reference file with all methods")
        return None

    # adjusting for int time
    ref_int_time = get_integration_time(reference_file)
    if ref_int_time:
        print(f"Reference Integration Time found: {ref_int_time}ms. Normalizing intensity.")
        ref_intensity = ref_intensity / ref_int_time
       

        print(f"NOTE: Intensities are now Counts/{ref_int_time}ms.")
    else:
        print("No integration time found in reference filename. Using raw counts.")

    
    ref_peak_wavelengths, ref_peak_intensities, _ = find_oes_peaks(
        ref_wavelength, ref_intensity, min_height, min_distance
    )
    
    print(f"Found {len(ref_peak_wavelengths)} peaks in reference spectrum")
    
    # Store results
    results = {
        'reference_file': reference_file,
        'reference_wavelength': ref_wavelength,
        'reference_intensity': ref_intensity,
        'reference_peaks': list(zip(ref_peak_wavelengths, ref_peak_intensities)),
        'reference_time': ref_int_time,
        'sample_results': {}
    }
    
  
    for sample_file in sample_files:
        print(f"Analyzing sample: {clean_string_for_filename(sample_file)}")
        sample_wavelength, sample_intensity = load_oes_data_simple(sample_file)
        
        if sample_wavelength is None:
            print(f"Trying alternative method for: {clean_string_for_filename(sample_file)}")
            sample_wavelength, sample_intensity = load_oes_data_manual(sample_file)
        
        if sample_wavelength is None:
            print(f"Error loading sample file: {sample_file}")
            continue
        
        # Check for Sample Integration Time and Adjust
        sample_int_time = get_integration_time(sample_file)
        if sample_int_time:
            print(f"Sample Integration Time found: {sample_int_time}ms. Adjusting intensity.")
            sample_intensity = sample_intensity / sample_int_time
        else:
            print("No integration time found in sample filename. Using raw counts (WARNING: Comparisons may be inaccurate).")
        t_vib = calculate_vibrational_temperature(sample_wavelength,sample_intensity)
        sample_peak_data = []
        
        # For each reference peak, find intensity in sample spectrum
        for ref_wl, ref_int in zip(ref_peak_wavelengths, ref_peak_intensities):
            sample_int, wavelength_diff = get_intensity_at_wavelength(
                sample_wavelength, sample_intensity, ref_wl, wavelength_tolerance
            )
            
            # Calculate intensity ratio (sample/reference)
            intensity_ratio = sample_int / ref_int if ref_int > 0 else 0
            
            sample_peak_data.append({
                'wavelength': ref_wl,
                'reference_intensity': ref_int,
                'sample_intensity': sample_int,
                'intensity_ratio': intensity_ratio,
                'wavelength_difference': wavelength_diff,
                'within_tolerance': wavelength_diff <= wavelength_tolerance
                
            })
        
        results['sample_results'][sample_file] = {
            'peak_data': sample_peak_data,
            'wavelength': sample_wavelength,
            'intensity': sample_intensity,
            'integration_time': sample_int_time,
            "Vibrational Temperature": t_vib
        }
    
    return results

