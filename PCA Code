def get_file_paths_dialog():
    
    root = tk.Tk()
    root.withdraw()
    root.attributes('-topmost', True)
    
    try:
        # Select reference file
        print("Select REF OES spectrum file...")
        reference_file = filedialog.askopenfilename(
            title="Select Reference OES Spectrum",
            filetypes=[("Text files", "*.txt"), ("CSV files", "*.csv"), ("All files", "*.*")]
        )
        
        if not reference_file:
            print("No reference file selected")
            return None, None
        
        # Select multiple sample files
        print("Select SAMPLE spectrum files to analyse...")
        sample_files = filedialog.askopenfilenames(
            title="Select Sample OES Spectra",
            filetypes=[("Text files", "*.txt"), ("CSV files", "*.csv"), ("All files", "*.*")]
        )
        
        if not sample_files:
            print("No sample files selected")
            return None, None
            
        return reference_file, list(sample_files)
        
    except Exception as e:
        print(f"Error in file dialog: {e}")
        return None, None
    finally:
        try:
            root.destroy()
        except:
            pass

def plot_vib_temp_trends(results):
    """Plots Vibrational Temperature vs Power and Pressure."""
    
    power_data = []
    pressure_data = []
    
    for filename, data in results['sample_results'].items():
        t_vib = data.get("Vibrational Temperature")
        
        if t_vib is None:
            continue
            
        power, pressure = extract_experiment_params(filename)
        
        if power is not None:
            power_data.append((power, t_vib))
        if pressure is not None:
            pressure_data.append((pressure, t_vib))
    
    power_data.sort(key=lambda x: x[0])
    pressure_data.sort(key=lambda x: x[0])
    
    if not power_data and not pressure_data:
        print("No Power (W) or Pressure (mTorr) found in filenames to plot trends.")
        return

    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(12, 5))
    fig.suptitle('Vibrational Temperature Trends', fontsize=16)
    
    if power_data:
        x_val, y_val = zip(*power_data)
        ax1.plot(x_val, y_val, 'bo-', linewidth=2, markersize=8)
        ax1.set_xlabel('Power (W)')
        ax1.set_ylabel('Vibrational Temperature (K)')
        ax1.set_title('Temperature vs Power')
        ax1.grid(True, alpha=0.3)
    else:
        ax1.text(0.5, 0.5, 'No Power Data (W) found', ha='center')

    if pressure_data:
        x_val, y_val = zip(*pressure_data)
        ax2.plot(x_val, y_val, 'ro-', linewidth=2, markersize=8)
        ax2.set_xlabel('Pressure (mTorr)')
        ax2.set_ylabel('Vibrational Temperature (K)')
        ax2.set_title('Temperature vs Pressure')
        ax2.grid(True, alpha=0.3)
    else:
        ax2.text(0.5, 0.5, 'No Pressure Data (mTorr) found', ha='center')

    plt.tight_layout()
    plt.show()

def reference_peak_analysis():
    
    print("\n=== REFERENCE PEAK ANALYSIS ===")
    print("This mode uses the first spectrum as reference and checks")
    print("intensities at reference peak positions in other spectra.")
    print("It also scans filenames for integration time (e.g. '50ms') to normalise intensities.")
    
    reference_file, sample_files = get_file_paths_dialog()
    
    if reference_file is None or sample_files is None:
        print("File selection cancelled or failed.")
        return None  # Return None so main() can check for failure
    
    print(f"Reference file: {clean_string_for_filename(reference_file)}")
    print(f"Sample files: {len(sample_files)} files selected")
    
    try:
        min_height = float(input("Enter minimum peak height (Note: Adjusts for int, this is counts/ms): ") or "50")
        min_distance = int(input("Enter minimum peak distance in data points (default 10): ") or "10")
        wavelength_tolerance = float(input("Enter wavelength tolerance for intensity lookup (default 0.1): ") or "0.1")
        
        min_height, min_distance, wavelength_tolerance = validate_parameters(
            min_height, min_distance, wavelength_tolerance
        )
    except ValueError as e:
        print(f"Parameter error: {e}. Using default parameters.")
        min_height = 50
        min_distance = 10
        wavelength_tolerance = 0.1
    
    results = analyse_multiple_spectra_at_reference_peaks(
        reference_file, sample_files, min_height, min_distance, wavelength_tolerance
    )
    
    if results is None:
        print("Analysis failed.")
        return None
    
    print("\n" + "="*70)
    print("REFERENCE PEAK ANALYSIS RESULTS")
    print("="*70)
    
    print(f"\nReference: {clean_string_for_filename(reference_file)}")
    if results.get('reference_time'):
        print(f"Reference Integration Time: {results['reference_time']} ms (Intensities normalised)")
    
    print(f"Found {len(results['reference_peaks'])} peaks in reference spectrum:")
    
    for i, (wl, inten) in enumerate(results['reference_peaks'], 1):
        print(f"  {i}. {wl:.4f} nm (Intensity: {inten:.4f})")
    
    for sample_file, sample_data in results['sample_results'].items():
        print(f"\n--- {clean_string_for_filename(sample_file)} ---")
        if sample_data.get('integration_time'):
            print(f"Integration Time: {sample_data['integration_time']} ms")
        t_vib = sample_data.get("Vibrational Temperature")
        if t_vib:
            print(f"Vibrational Temperature: {t_vib:.2f} K")
        else:
            print("Vibrational Temperature: N/A")
        peak_data = sample_data['peak_data']
        
        peaks_in_tolerance = sum(1 for p in peak_data if p['within_tolerance'])
        print(f"Peaks within tolerance: {peaks_in_tolerance}/{len(peak_data)}")
        
        for i, peak in enumerate(peak_data, 1):
            status = "✓" if peak['within_tolerance'] else "✗"
            print(f"  {i}. {peak['wavelength']:.4f} nm {status}")
            print(f"     Ref: {peak['reference_intensity']:.4f}, Sample: {peak['sample_intensity']:.4f}")
            print(f"     Ratio: {peak['intensity_ratio']:.4f}, Wavelength diff: {peak['wavelength_difference']:.4f} nm")
    
    # Save results
    save_results = input("\nSave results to file? (y/n, default=y): ").lower() or "y"
    if save_results.startswith('y'):
        root = tk.Tk()
        root.withdraw()
        output_file = filedialog.asksaveasfilename(
            title="Save Reference Peak Analysis Results",
            defaultextension=".txt",
            filetypes=[("Text files", "*.txt"), ("All files", "*.*")]
        )
        if output_file:
            save_reference_peak_analysis(results, output_file)
            print(f"Results saved to {output_file}")

    # FIX 5: Ask BEFORE plotting, not after
    plot_results = input("\nPlot results? (y/n, default=y): ").lower() or "y"
    if plot_results.startswith('y'):
        print("Generating plots...")
        plot_reference_peak_analysis(results)
        plot_vib_temp_trends(results)
        for sample_file, sample_data in results['sample_results'].items():
            if sample_data.get("Boltz_Plot_Data"):
                plot_boltzmann_fit(sample_data["Boltz_Plot_Data"])

    return results  # Return results so main() can use them for PCA

def main():
    """Main function"""
    print("OES Spectrum Reference Peak Analysis Tool")
    print("=" * 50)
    print("This tool analyses multiple spectra at the peak positions")
    print("identified in a reference spectrum.")
    
    # FIX 2 & 3: reference_peak_analysis() now does the full workflow and returns results.
    # main() uses those results for PCA rather than re-running file dialogs with undefined variables.
    results = reference_peak_analysis()

